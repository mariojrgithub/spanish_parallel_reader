# Default model: qwen2.5:7b (Apache 2.0 license — commercial use allowed)
# Optional model: qwen2.5:14b (requires ~12 GB RAM)
# Pull before starting:
#   ollama pull qwen2.5:7b
#   ollama pull qwen2.5:14b
# Uncomment to switch default:
# OLLAMA_MODEL=qwen2.5:14b
OLLAMA_MODEL=qwen2.5:7b
AVAILABLE_OLLAMA_MODELS=qwen2.5:7b,qwen2.5:14b
OLLAMA_HOST=http://localhost:11434
# Keep the model loaded indefinitely between requests (-1 = infinite).
OLLAMA_KEEP_ALIVE=-1
# Context window size in tokens. 8192 works for all supported models.
# Increase for very long chunks (e.g. 12288) if your GPU has enough VRAM.
OLLAMA_NUM_CTX=8192
MAX_CHARS_PER_CHUNK=2200
APP_HOST_PORT=8502

# ──────────────────────────────────────────────────────────────
# Output Checker settings
# All checking uses the local Ollama endpoint — no data leaves your machine.
# ──────────────────────────────────────────────────────────────

# Enable or disable the checker entirely (true/false)
CHECKER_ENABLED=true

# Checker mode:
#   off    — no checks at all
#   fast   — deterministic checks only (no extra model calls)
#   smart  — deterministic + LLM for risky/sampled pairs (recommended)
#   strict — deterministic + LLM for every pair (slowest, highest confidence)
CHECKER_MODE=fast

# Checker model. Leave empty to use the same model as translation (OLLAMA_MODEL).
# Set to a different model if you want a dedicated checker model.
CHECKER_MODEL=

# Fraction of pairs to LLM-check when they are not already flagged as risky.
# 1.0 = check all sampled pairs; 0.5 = sample half; 0.0 = only check risky pairs.
CHECKER_SAMPLE_RATE=1.0

# Maximum characters sent to the LLM checker per field (English or Spanish).
# Reducing this speeds up checker calls at the cost of partial coverage.
CHECKER_MAX_CHARS=2500

# If true, Markdown export is blocked for pairs that do not pass the checker.
# false (default) allows export with checker warnings included in the output.
CHECKER_REQUIRE_PASS=false

# Timeout in seconds for a single LLM checker call.
# Keep below the translation timeout to prevent checker calls from dominating.
CHECKER_TIMEOUT_SECONDS=45

# Enable or disable the in-session cache for checker results (true/false).
# When enabled, the checker is skipped for pairs already checked this session.
CHECKER_CACHE_ENABLED=true

# Show per-issue breakdown in the UI (true/false).
# Keep false for a faster, cleaner interface. Enable for debugging.
CHECKER_DETAILED_DIAGNOSTICS=false

# Enable or disable LLM-based checking (true/false).
# When false, only deterministic checks run regardless of CHECKER_MODE.
CHECKER_LLM_ENABLED=true

# Number of pairs to check concurrently.
# Values > 1 only improve throughput when CHECKER_MODEL is a dedicated second model
# (concurrent calls to the same model queue serially on the GPU anyway).
CHECKER_BATCH_SIZE=3
