# Default model: aya-expanse:8b
# License: Aya Expanse 8B is released under CC-BY-NC (Creative Commons By-Attribution-NonCommercial).
# Non-commercial use only. Verify compatibility before deployment.
# Details: https://huggingface.co/CohereForAI/aya-expanse-8b
# Hardware: Aya Expanse 8B requires 8–16 GB RAM; 8 GB+ VRAM recommended for GPU.
# Reduce MAX_CHARS_PER_CHUNK if you run out of memory.
# Uncomment the line below to switch models:
# OLLAMA_MODEL=qwen3:8b
OLLAMA_MODEL=aya-expanse:8b
OLLAMA_HOST=http://ollama:11434
OLLAMA_KEEP_ALIVE=10m
MAX_CHARS_PER_CHUNK=2200
APP_HOST_PORT=8502
